<footer>
  <div class="container">
    <div class="footer-inner">
      <a href="#" class="footer-brand">
        <img src="/assets/imagenes/logo-falconx.svg" alt="FalconX AI" width="20" height="20">
        Falcon<span class="x-grad">X</span> AI
      </a>
      <p class="footer-copy">© 2025 FalconX AI · contacto@falconx.cl · <a href="/privacidad">Política de Privacidad</a></p>
    </div>
  </div>
</footer>

<style>
  footer { padding: 28px 0; border-top: 1px solid var(--border); }
  .footer-inner { display: flex; align-items: center; justify-content: space-between; }
  .footer-brand { display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--text-muted); font-family: var(--font-h); font-size: 0.875rem; font-weight: 500; }
  .footer-brand img { width: 20px; height: 20px; object-fit: contain; }
  .footer-copy { color: var(--text-muted); font-size: 0.78rem; }
  .footer-copy a { color: var(--text-muted); text-decoration: none; transition: color var(--ease); }
  .footer-copy a:hover { color: var(--accent); }
</style>
