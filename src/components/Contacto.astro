---
---
<section id="contacto">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-left reveal">
        <div class="contact-logo">
          <img src="/assets/imagenes/logo-falconx.svg" alt="FalconX AI" width="96" height="96">
        </div>
        <p class="s-label">Contacto</p>
        <h2>¿Listo para automatizar?</h2>
        <p>Cuéntanos qué proceso quieres automatizar. En 24 horas te respondemos con un diagnóstico inicial sin costo.</p>
        <div class="contact-links">
          <a href="mailto:contacto@falconx.cl">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            contacto@falconx.cl
          </a>
          <a href="https://falconx.cl" target="_blank" rel="noopener">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            falconx.cl
          </a>
        </div>
      </div>

      <div class="reveal">
        <form class="form" id="contactForm" name="contacto" data-netlify="true" novalidate>
          <input type="hidden" name="form-name" value="contacto">
          <div class="form-row">
            <div class="fg"><label for="nombre">Nombre *</label><input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required autocomplete="name"></div>
            <div class="fg"><label for="empresa">Empresa</label><input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa" autocomplete="organization"></div>
          </div>
          <div class="form-row">
            <div class="fg"><label for="email">Email *</label><input type="email" id="email" name="email" placeholder="tu@empresa.com" required autocomplete="email"></div>
            <div class="fg"><label for="telefono">WhatsApp</label><input type="tel" id="telefono" name="telefono" placeholder="+56 9 XXXX XXXX" autocomplete="tel"></div>
          </div>
          <div class="fg">
            <label for="servicio">¿Qué te interesa?</label>
            <select id="servicio" name="servicio">
              <option value="">Selecciona un servicio</option>
              <option value="agente-whatsapp">Agente de IA para WhatsApp</option>
              <option value="notificaciones">Tuberías de notificación</option>
              <option value="integracion">Integración de sistemas</option>
              <option value="bot-humano">Control BOT / Humano</option>
              <option value="templates">Gestión de templates Meta</option>
              <option value="medida">Proyecto a medida</option>
            </select>
          </div>
          <div class="fg">
            <label for="mensaje">Cuéntanos tu caso</label>
            <textarea id="mensaje" name="mensaje" placeholder="¿Qué proceso quieres automatizar? ¿Qué sistemas usas hoy?"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-submit">Enviar solicitud</button>
        </form>
        <div class="form-ok" id="formOk">
          <div class="ok-particles" id="okParticles"></div>
          <div class="ok-icon-wrap">
            <div class="ok-ring"></div>
            <svg class="ok-check" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle class="ok-circle" cx="26" cy="26" r="24" stroke-width="1.5"/>
              <path class="ok-path" d="M14 27l8 8 16-16" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="ok-title">¡Solicitud enviada!</h3>
          <p class="ok-sub">Te contactamos en menos de 24 horas con un diagnóstico inicial sin costo.</p>
          <div class="ok-chips">
            <span class="ok-chip">Diagnóstico gratuito</span>
            <span class="ok-chip">Respuesta &lt;24h</span>
            <span class="ok-chip">Sin compromisos</span>
          </div>
          <button class="btn btn-ghost ok-reset" id="okReset">Enviar otra consulta</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-logo { width: 96px; height: 96px; margin-bottom: 24px; }
  .contact-logo img { width: 100%; height: 100%; object-fit: contain; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 80px; align-items: start; }
  .contact-left h2 { font-family: var(--font-h); font-size: clamp(1.7rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 16px; }
  .contact-left p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.75; font-weight: 300; margin-bottom: 32px; }
  .contact-links { display: flex; flex-direction: column; gap: 12px; }
  .contact-links a { display: flex; align-items: center; gap: 10px; color: var(--text-secondary); text-decoration: none; font-size: 0.875rem; transition: color var(--ease); }
  .contact-links a:hover { color: var(--accent); }
  .form { display: flex; flex-direction: column; gap: 16px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .fg { display: flex; flex-direction: column; gap: 6px; }
  .fg label { font-family: var(--font-h); font-size: 0.78rem; font-weight: 500; color: var(--text-secondary); }
  .fg input, .fg textarea, .fg select { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-sm); color: var(--text-primary); font-family: var(--font-b); font-size: 0.875rem; padding: 12px 16px; outline: none; width: 100%; transition: border-color var(--ease); }
  .fg input:focus, .fg textarea:focus, .fg select:focus { border-color: var(--accent-border); }
  .fg input::placeholder, .fg textarea::placeholder { color: var(--text-muted); }
  .fg select { appearance: none; cursor: pointer; }
  .fg textarea { resize: vertical; min-height: 116px; }
  .btn-submit { width: 100%; padding: 14px; font-size: 0.95rem; }
  .form-error { color: #f87171; font-size: 0.75rem; margin-top: 2px; display: none; }
  .fg input.invalid, .fg textarea.invalid { border-color: #f87171; }

  /* ── Success panel ── */
  .form-ok {
    display: none;
    position: relative;
    overflow: visible;
    text-align: center;
    padding: 48px 24px 40px;
    min-height: 320px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
  .ok-particles {
    position: absolute; inset: 0;
    pointer-events: none; overflow: visible; z-index: 0;
  }
  .ok-icon-wrap {
    position: relative;
    width: 92px; height: 92px;
    margin: 0 auto 28px;
    z-index: 1;
  }
  .ok-ring {
    position: absolute;
    inset: -12px; border-radius: 50%;
    background: radial-gradient(circle, rgba(168,85,247,0.35) 0%, transparent 70%);
    animation: ok-pulse 2.4s ease-in-out infinite;
  }
  @keyframes ok-pulse {
    0%, 100% { transform: scale(1);    opacity: 0.5; }
    50%       { transform: scale(1.18); opacity: 1;   }
  }
  .ok-check {
    width: 92px; height: 92px;
    position: relative; z-index: 1;
  }
  .ok-circle {
    stroke: var(--accent);
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    animation: ok-draw 0.65s cubic-bezier(0.65,0,0.45,1) 0.1s forwards;
  }
  .ok-path {
    stroke: var(--accent);
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: ok-draw 0.35s cubic-bezier(0.65,0,0.45,1) 0.6s forwards;
  }
  @keyframes ok-draw { to { stroke-dashoffset: 0; } }

  .ok-title {
    font-family: var(--font-h); font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700; letter-spacing: -0.03em;
    margin-bottom: 12px; position: relative; z-index: 1;
  }
  .ok-sub {
    color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7;
    max-width: 320px; margin: 0 auto 24px;
    position: relative; z-index: 1;
  }
  .ok-chips {
    display: flex; gap: 8px; flex-wrap: wrap;
    justify-content: center; margin-bottom: 28px;
    position: relative; z-index: 1;
  }
  .ok-chip {
    background: var(--accent-dim); border: 1px solid var(--accent-border);
    color: var(--accent); font-family: var(--font-h);
    font-size: 0.72rem; font-weight: 500;
    padding: 4px 12px; border-radius: 100px;
  }
  .ok-chip::before { content: '✓ '; }
  .ok-reset { position: relative; z-index: 1; }
</style>

<script>
  import { gsap } from 'gsap';

  const form  = document.getElementById('contactForm') as HTMLFormElement | null;
  const okPanel = document.getElementById('formOk') as HTMLElement | null;

  function burstParticles() {
    const layer = document.getElementById('okParticles');
    if (!layer || !okPanel) return;
    const colors = ['#A855F7','#E879F9','#C084FC','#ffffff','#6D28D9'];
    const cx = okPanel.offsetWidth / 2;
    const cy = 100; // approx center of icon
    for (let i = 0; i < 32; i++) {
      const p = document.createElement('span');
      const size = 3 + Math.random() * 5;
      p.style.cssText = `position:absolute;width:${size}px;height:${size}px;border-radius:50%;background:${colors[Math.floor(Math.random()*colors.length)]};top:${cy}px;left:${cx}px;`;
      layer.appendChild(p);
      const angle = Math.random() * Math.PI * 2;
      const dist  = 70 + Math.random() * 150;
      gsap.fromTo(p,
        { x: 0, y: 0, scale: 0, opacity: 1 },
        { x: Math.cos(angle) * dist, y: Math.sin(angle) * dist,
          scale: 1 + Math.random(), opacity: 0,
          duration: 0.7 + Math.random() * 0.5,
          ease: 'power2.out',
          delay: Math.random() * 0.18,
          onComplete: () => p.remove() }
      );
    }
  }

  function showSuccess() {
    if (!form || !okPanel) return;
    form.style.display = 'none';
    okPanel.style.display = 'flex';

    burstParticles();

    gsap.timeline()
      .fromTo(okPanel,       { opacity: 0, scale: 0.88 }, { opacity: 1, scale: 1, duration: 0.55, ease: 'back.out(1.5)' })
      .fromTo('.ok-title',   { opacity: 0, y: 18 },       { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }, '-=0.15')
      .fromTo('.ok-sub',     { opacity: 0, y: 12 },       { opacity: 1, y: 0, duration: 0.35, ease: 'power2.out' }, '-=0.2')
      .fromTo('.ok-chips',   { opacity: 0, y: 10 },       { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' }, '-=0.15')
      .fromTo('.ok-reset',   { opacity: 0, y: 8 },        { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' }, '-=0.1');
  }

  form?.addEventListener('submit', async function(e) {
    e.preventDefault();

    const nombreEl = document.getElementById('nombre') as HTMLInputElement;
    const emailEl  = document.getElementById('email')  as HTMLInputElement;
    const nombre   = nombreEl?.value.trim() ?? '';
    const email    = emailEl?.value.trim()  ?? '';
    let valid      = true;

    if (!nombre) { nombreEl?.classList.add('invalid');    valid = false; }
    else          { nombreEl?.classList.remove('invalid');               }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
    if (!email || !emailRegex.test(email)) { emailEl?.classList.add('invalid');    valid = false; }
    else                                   { emailEl?.classList.remove('invalid');               }

    if (!valid) return;

    const btn = this.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }

    try {
      const formData = new FormData(this);
      const params   = new URLSearchParams();
      formData.forEach((value, key) => params.append(key, value.toString()));

      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params.toString(),
      });

      if (res.ok) {
        showSuccess();
      } else {
        if (btn) { btn.disabled = false; btn.textContent = 'Enviar solicitud'; }
      }
    } catch {
      if (btn) { btn.disabled = false; btn.textContent = 'Enviar solicitud'; }
    }
  });

  document.getElementById('okReset')?.addEventListener('click', () => {
    if (!form || !okPanel) return;
    okPanel.style.display = 'none';
    form.reset();
    form.style.display = 'flex';
    gsap.fromTo(form, { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' });
  });
</script>
