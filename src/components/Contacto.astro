---
---
<section id="contacto">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-left reveal">
        <div class="contact-logo">
          <img src="/assets/imagenes/logo-falconx.svg" alt="FalconX AI" width="96" height="96">
        </div>
        <p class="s-label">Contacto</p>
        <h2>¿Listo para automatizar?</h2>
        <p>Cuéntanos qué proceso quieres automatizar. En 24 horas te respondemos con un diagnóstico inicial sin costo.</p>
        <div class="contact-links">
          <a href="mailto:contacto@falconx.cl">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            contacto@falconx.cl
          </a>
          <a href="https://falconx.cl" target="_blank" rel="noopener">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            falconx.cl
          </a>
        </div>
      </div>

      <div class="reveal">
        <form class="form" id="contactForm" novalidate>
          <div class="form-row">
            <div class="fg"><label for="nombre">Nombre *</label><input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required autocomplete="name"></div>
            <div class="fg"><label for="empresa">Empresa</label><input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa" autocomplete="organization"></div>
          </div>
          <div class="form-row">
            <div class="fg"><label for="email">Email *</label><input type="email" id="email" name="email" placeholder="tu@empresa.com" required autocomplete="email"></div>
            <div class="fg"><label for="telefono">WhatsApp</label><input type="tel" id="telefono" name="telefono" placeholder="+56 9 XXXX XXXX" autocomplete="tel"></div>
          </div>
          <div class="fg">
            <label for="servicio">¿Qué te interesa?</label>
            <select id="servicio" name="servicio">
              <option value="">Selecciona un servicio</option>
              <option value="agente-whatsapp">Agente de IA para WhatsApp</option>
              <option value="notificaciones">Tuberías de notificación</option>
              <option value="integracion">Integración de sistemas</option>
              <option value="bot-humano">Control BOT / Humano</option>
              <option value="templates">Gestión de templates Meta</option>
              <option value="medida">Proyecto a medida</option>
            </select>
          </div>
          <div class="fg">
            <label for="mensaje">Cuéntanos tu caso</label>
            <textarea id="mensaje" name="mensaje" placeholder="¿Qué proceso quieres automatizar? ¿Qué sistemas usas hoy?"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-submit">Enviar solicitud</button>
        </form>
        <div class="form-ok" id="formOk">✓ Solicitud recibida. Te contactamos en menos de 24 horas.</div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-logo { width: 96px; height: 96px; margin-bottom: 24px; }
  .contact-logo img { width: 100%; height: 100%; object-fit: contain; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: 80px; align-items: start; }
  .contact-left h2 { font-family: var(--font-h); font-size: clamp(1.7rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 16px; }
  .contact-left p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.75; font-weight: 300; margin-bottom: 32px; }
  .contact-links { display: flex; flex-direction: column; gap: 12px; }
  .contact-links a { display: flex; align-items: center; gap: 10px; color: var(--text-secondary); text-decoration: none; font-size: 0.875rem; transition: color var(--ease); }
  .contact-links a:hover { color: var(--accent); }
  .form { display: flex; flex-direction: column; gap: 16px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .fg { display: flex; flex-direction: column; gap: 6px; }
  .fg label { font-family: var(--font-h); font-size: 0.78rem; font-weight: 500; color: var(--text-secondary); }
  .fg input, .fg textarea, .fg select { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-sm); color: var(--text-primary); font-family: var(--font-b); font-size: 0.875rem; padding: 12px 16px; outline: none; width: 100%; transition: border-color var(--ease); }
  .fg input:focus, .fg textarea:focus, .fg select:focus { border-color: var(--accent-border); }
  .fg input::placeholder, .fg textarea::placeholder { color: var(--text-muted); }
  .fg select { appearance: none; cursor: pointer; }
  .fg textarea { resize: vertical; min-height: 116px; }
  .btn-submit { width: 100%; padding: 14px; font-size: 0.95rem; }
  .form-ok { display: none; text-align: center; padding: 40px; color: var(--accent); font-family: var(--font-h); font-size: 1rem; }
</style>

<script>
  document.getElementById('contactForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const nombre = (document.getElementById('nombre') as HTMLInputElement)?.value.trim();
    const email  = (document.getElementById('email')  as HTMLInputElement)?.value.trim();
    if (!nombre || !email) return;
    (this as HTMLFormElement).style.display = 'none';
    const ok = document.getElementById('formOk');
    if (ok) ok.style.display = 'block';
  });
</script>
