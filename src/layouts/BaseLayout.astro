---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'FalconX AI — IA que trabaja 24/7 por tu empresa',
  description = 'FalconX AI — Automatización de comunicación con IA para empresas. WhatsApp Business, redes sociales e integraciones a medida.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://falconx.cl">
  <title>{title}</title>
  <link rel="icon" href="/assets/imagenes/logo-falconx.svg" type="image/svg+xml">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
</head>
<body>

<div class="aurora" aria-hidden="true">
  <div class="aurora-blob aurora-1"></div>
  <div class="aurora-blob aurora-2"></div>
  <div class="aurora-blob aurora-3"></div>
</div>

<slot />

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
